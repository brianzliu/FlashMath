{
  "permissions": {
    "allow": [
      "Bash(node:*)",
      "Bash(npm --version:*)",
      "Bash(npx:*)",
      "Bash(rustc:*)",
      "Bash(cargo --version:*)",
      "Bash(cargo install:*)",
      "Bash(npm init:*)",
      "Bash(npm install:*)",
      "Bash(cargo tauri init:*)",
      "Bash(cargo check:*)",
      "Bash(npm run build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo tauri build:*)",
      "Bash(cargo tauri dev:*)",
      "Bash(ls:*)",
      "Bash(npm uninstall:*)",
      "Bash(lsof:*)",
      "Bash(xargs kill:*)",
      "Bash(python3:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H \"Content-Type: application/json\" -H \"X-Emdash-Token: $EMDASH_HOOK_TOKEN\" -H \"X-Emdash-Pty-Id: $EMDASH_PTY_ID\" -H \"X-Emdash-Event-Type: notification\" -d @- \"http://127.0.0.1:$EMDASH_HOOK_PORT/hook\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H \"Content-Type: application/json\" -H \"X-Emdash-Token: $EMDASH_HOOK_TOKEN\" -H \"X-Emdash-Pty-Id: $EMDASH_PTY_ID\" -H \"X-Emdash-Event-Type: stop\" -d @- \"http://127.0.0.1:$EMDASH_HOOK_PORT/hook\" || true"
          }
        ]
      }
    ]
  }
}
